*&---------------------------------------------------------------------*
*& Form SUB_ZFAN_DATA
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM sub_zfan_data .

  DATA : lt_alv TYPE TABLE OF ty_alv .
  DATA : lwa_alv TYPE ty_alv .

  DATA : lwa_d020s TYPE d020s .
  DATA : lwa_rsmptexts TYPE rsmptexts .
  DATA : lwa_tstc TYPE tstc .

  lt_alv[] = gt_alv[] .

  DELETE lt_alv WHERE selec = '' .
  SORT lt_alv BY name .
  DELETE ADJACENT DUPLICATES FROM lt_alv
           COMPARING name .

  LOOP AT lt_alv INTO lwa_alv .



    "事务码
    LOOP AT gt_tstc INTO lwa_tstc  WHERE pgmna = lwa_alv-name .

      "事务码
      CLEAR  lwa_alv-lobjn .
      lwa_alv-lobjn   =  lwa_tstc-tcode ."翻译对象
      PERFORM sub_up_trans  USING lwa_alv
                                   'TRAN'
                                   'LXE_OBJ_TEXT_WRITE_TRAN'   .
    ENDLOOP  .


    "报表元素
    CLEAR  lwa_alv-lobjn .
    lwa_alv-lobjn   =  lwa_alv-name ."翻译对象
    PERFORM sub_up_trans  USING lwa_alv
                                 'REPT'
                                 'LXE_OBJ_TEXT_WRITE_REPT'   .

    "屏幕元素
    LOOP AT gt_d020s INTO lwa_d020s  WHERE prog  = lwa_alv-name.

*      LWA_ALV-LOBJN   =  LWA_ALV-NAME &&  LWA_D020S-DNUM ."翻译对象
      CLEAR lwa_alv-lobjn .
      CONCATENATE lwa_d020s-prog  lwa_d020s-dnum  INTO lwa_alv-lobjn RESPECTING BLANKS .
      PERFORM sub_up_trans  USING lwa_alv
                            'SCRT'
                            'LXE_OBJ_TEXT_WRITE_SCRT'  .
*      PERFORM frm_active_screen USING lwa_d020s . "DELETE BY CHANGXY 20231205

    ENDLOOP  .

    "状态栏元素
    LOOP AT gt_rsmptexts INTO lwa_rsmptexts  WHERE progname  = lwa_alv-name.

*      LWA_ALV-LOBJN   =  LWA_ALV-NAME &&  LWA_D020S-DNUM ."翻译对象
      CLEAR lwa_alv-lobjn .
      CONCATENATE lwa_rsmptexts-progname   lwa_rsmptexts-obj_code  INTO lwa_alv-lobjn RESPECTING BLANKS .
      PERFORM sub_up_trans  USING lwa_alv
                      'CUA'
                      'LXE_OBJ_TEXT_WRITE_CUA'.

    ENDLOOP  .

*    COMMIT WORK AND WAIT .
    lwa_alv-light = '3' .
    MODIFY gt_alv FROM lwa_alv
         TRANSPORTING  light
          WHERE name =  lwa_alv-name
            AND selec = 'X' .


  ENDLOOP .






ENDFORM.
*&---------------------------------------------------------------------*
*& Form SUB_UP_TRANS
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*&      --> LT_PCX
*&      --> LWA_ALV
*&---------------------------------------------------------------------*
FORM sub_up_trans  USING    pwa_alv TYPE ty_alv
                             pv_type TYPE lxeobjtype
                             pv_zfan .

  DATA : lwa_pcx TYPE lxe_pcx_s1 .
  DATA : lwa_pcxd TYPE lxe_pcx_s1 .
  DATA : lt_pcx TYPE TABLE OF lxe_pcx_s1 .
  DATA : lt_pcxl TYPE TABLE OF lxe_pcx_s1 ."临时存储屏幕 屏幕翻译需要先进行读取
  DATA : lt_pcxd TYPE TABLE OF lxe_pcx_s1 ."删除屏幕翻译 屏幕翻译需要先进行删除

  CLEAR lt_pcx .
  LOOP AT gt_alv INTO gwa_alv WHERE name = pwa_alv-name
                                AND ltype =  pv_type
                                AND lobjn =  pwa_alv-lobjn  .
*                                 AND SELEC = 'X' .
    CLEAR lwa_pcx  .
    MOVE-CORRESPONDING  gwa_alv TO lwa_pcx .
    MOVE-CORRESPONDING  gwa_alv TO lwa_pcxd .
    IF gwa_alv-selec = 'X' .
      lwa_pcx-t_text = gwa_alv-zdco1 .
      lwa_pcxd-t_text = '' .
    ELSE .
      lwa_pcx-t_text = gwa_alv-t_text .
      lwa_pcxd-t_text = gwa_alv-t_text .
    ENDIF .
    APPEND lwa_pcx  TO lt_pcx .
    APPEND lwa_pcxd  TO lt_pcxd .

  ENDLOOP .
  IF sy-subrc = 0 .

    IF gwa_alv-ltype = 'SCRT' .
      CALL FUNCTION 'LXE_OBJ_TEXT_PAIR_READ_SCRT'
        EXPORTING
          t_r3_lang = p_lang2
          s_r3_lang = p_lang1
          objtype   = gwa_alv-ltype
          objname   = gwa_alv-lobjn
          read_only = ''
        TABLES
          lt_pcx_s1 = lt_pcxl.

**      SET UPDATE TASK LOCAL .
*      CALL FUNCTION PV_ZFAN
*        EXPORTING
*          R3_LANG   = P_LANG2
*          OBJTYPE   = GWA_ALV-LTYPE
*          OBJNAME   = GWA_ALV-LOBJN
*        TABLES
*          LT_PCX_S1 = LT_PCXD.
*      IF SY-SUBRC = 0 .
*        COMMIT WORK AND WAIT .
*        WAIT UP TO 1 SECONDS .
*      ENDIF .
    ENDIF .

*    SET UPDATE TASK LOCAL .
*    IF GWA_ALV-LTYPE <> 'SCRT' .
    CALL FUNCTION pv_zfan
      EXPORTING
        r3_lang   = p_lang2
        objtype   = gwa_alv-ltype
        objname   = gwa_alv-lobjn
      TABLES
        lt_pcx_s1 = lt_pcx.
    IF sy-subrc = 0 .
      COMMIT WORK AND WAIT .
    ENDIF .
*    ENDIF .
  ENDIF .

ENDFORM.
