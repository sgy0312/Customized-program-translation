FORM sub_deal_data .

  DATA : lwa_trdir TYPE trdir .
  DATA : lwa_rsmptexts TYPE rsmptexts  .
  DATA : lwa_d020s     TYPE d020s .
  DATA : lwa_tstc TYPE tstc .

  DATA : lwa_pcx TYPE lxe_pcx_s1 .
  DATA : lt_pcx TYPE TABLE OF lxe_pcx_s1 .

  DATA : lwa_alv TYPE ty_alv .

  DATA : lv_lobjn TYPE lxeobjname .

*    DATA : GT_RSMPTEXTS TYPE TABLE OF RSMPTEXTS  .
*    DATA : GT_D020S     TYPE TABLE OF D020S .

  CLEAR gt_alv .

  LOOP AT gt_trdir INTO lwa_trdir .

    "事务码
    LOOP AT gt_tstc INTO lwa_tstc  WHERE pgmna = lwa_trdir-name .
      CLEAR lwa_alv .
      CLEAR lt_pcx .
      lwa_alv-ltype   = 'TRAN'  ."翻译对象类型
      lwa_alv-light = '2' .
      lwa_alv-name = lwa_trdir-name .
      lwa_alv-lang1 = p_lang1  .
      lwa_alv-lang2 = p_lang2  .
      lwa_alv-lobjn   =  lwa_trdir-name ."翻译对象
      CALL FUNCTION 'LXE_OBJ_TEXT_PAIR_READ_TRAN'
        EXPORTING
          t_r3_lang = p_lang2
          s_r3_lang = p_lang1
          objtype   = lwa_alv-ltype
          objname   = lwa_alv-lobjn
          read_only = 'X'
*          read_only = 'X'
        TABLES
          lt_pcx_s1 = lt_pcx.
      PERFORM sub_add_alv TABLES lt_pcx
                          USING lwa_alv .
    ENDLOOP  .



    "报表元素
    CLEAR lwa_alv .
    CLEAR lt_pcx .
    lwa_alv-ltype   = 'REPT'  ."翻译对象类型
    lwa_alv-light   = '2' .
    lwa_alv-name    = lwa_trdir-name .
    lwa_alv-lobjn   =  lwa_trdir-name ."翻译对象
    lwa_alv-lang1 = p_lang1  .
    lwa_alv-lang2 = p_lang2  .
    CALL FUNCTION 'LXE_OBJ_TEXT_PAIR_READ_REPT'
      EXPORTING
        t_r3_lang = p_lang2
        s_r3_lang = p_lang1
        o_r3_lang = p_lang1
        objtype   = lwa_alv-ltype
        objname   = lwa_alv-lobjn
        read_only = '' "
*        read_only = 'X' "DELETE BY SIE-CHANGXY 20231125
      TABLES
        lt_pcx_s1 = lt_pcx.
    PERFORM sub_add_alv TABLES lt_pcx
                        USING lwa_alv .


    "屏幕元素
    LOOP AT gt_d020s INTO lwa_d020s  WHERE prog = lwa_trdir-name .
      CLEAR lwa_alv .
      CLEAR lt_pcx .
      lwa_alv-ltype   = 'SCRT'  ."翻译对象类型
      lwa_alv-light = '2' .
      lwa_alv-name = lwa_trdir-name .
      lwa_alv-lang1 = p_lang1  .
      lwa_alv-lang2 = p_lang2  .
*      LWA_ALV-LOBJN   =  LWA_TRDIR-NAME &&  LWA_D020S-DNUM ."翻译对象
      CONCATENATE lwa_trdir-name  lwa_d020s-dnum  INTO lwa_alv-lobjn RESPECTING BLANKS .
      CALL FUNCTION 'LXE_OBJ_TEXT_PAIR_READ_SCRT'
        EXPORTING
          t_r3_lang = p_lang2
          s_r3_lang = p_lang1
          objtype   = lwa_alv-ltype
          objname   = lwa_alv-lobjn
          read_only = 'X'
        TABLES
          lt_pcx_s1 = lt_pcx.
      PERFORM sub_add_alv TABLES lt_pcx
                          USING lwa_alv .
    ENDLOOP  .

*    "菜单元素
*    LOOP AT GT_RSMPTEXTS INTO LWA_RSMPTEXTS WHERE PROGNAME = LWA_TRDIR-NAME.
*      CLEAR LWA_ALV .
*      CLEAR LT_PCX .
*      LWA_ALV-LTYPE   = 'SCRH'  ."翻译对象类型
*      LWA_ALV-LIGHT = '2' .
*      LWA_ALV-NAME = LWA_TRDIR-NAME .
**      LWA_ALV-LOBJN   =  LWA_TRDIR-NAME &&  LWA_RSMPTEXTS-OBJ_CODE ."翻译对象
*      CONCATENATE LWA_TRDIR-NAME  LWA_RSMPTEXTS-OBJ_CODE INTO LWA_ALV-LOBJN RESPECTING BLANKS .
*      CALL FUNCTION 'LXE_OBJ_TEXT_PAIR_READ_SCRH'
*        EXPORTING
*          T_R3_LANG = P_LANG2
*          S_R3_LANG = P_LANG1
*          OBJTYPE   = LWA_ALV-LTYPE
*          OBJNAME   = LWA_ALV-LOBJN
*          READ_ONLY = 'X'
*        TABLES
*          LT_PCX_S1 = LT_PCX.
*
*      PERFORM SUB_ADD_ALV TABLES LT_PCX
*                          USING LWA_ALV .
*    ENDLOOP  .

    "菜单元素
    LOOP AT gt_rsmptexts INTO lwa_rsmptexts WHERE progname = lwa_trdir-name.
      CLEAR lwa_alv .
      CLEAR lt_pcx .
      lwa_alv-ltype   = 'CUA'  ."翻译对象类型
      lwa_alv-light   = '2' .
      lwa_alv-name    = lwa_trdir-name .
      lwa_alv-lang1   = p_lang1  .
      lwa_alv-lang2   = p_lang2  .
*      LWA_ALV-LOBJN   =  LWA_TRDIR-NAME &&  LWA_RSMPTEXTS-OBJ_CODE ."翻译对象
      CONCATENATE lwa_trdir-name  lwa_rsmptexts-obj_code INTO lwa_alv-lobjn RESPECTING BLANKS .
      CALL FUNCTION 'LXE_OBJ_TEXT_PAIR_READ_CUA'
        EXPORTING
          t_r3_lang = p_lang2
          s_r3_lang = p_lang1
          objtype   = lwa_alv-ltype
          objname   = lwa_alv-lobjn
          read_only = 'X'
        TABLES
          lt_pcx_s1 = lt_pcx.

      PERFORM sub_add_alv TABLES lt_pcx
                          USING lwa_alv .
