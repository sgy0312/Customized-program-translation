*& <--  p2        text
*&---------------------------------------------------------------------*
FORM sub_get_d020s .

  CLEAR gt_d020s .

  SELECT *
    INTO TABLE gt_d020s
    FROM d020s
    FOR ALL ENTRIES IN gt_trdir
    WHERE prog = gt_trdir-name
      AND dnum <> '1000' .

ENDFORM.
*&---------------------------------------------------------------------*
*& Form SUB_GET_RSMPTEXTS
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM sub_get_rsmptexts .

  CLEAR gt_rsmptexts .

  SELECT *
    INTO TABLE gt_rsmptexts
    FROM rsmptexts
    FOR ALL ENTRIES IN gt_trdir
    WHERE progname = gt_trdir-name
      AND sprsl = p_lang1
      AND obj_type = 'C' .

ENDFORM.
*&---------------------------------------------------------------------*
*& Form SUB_GET_TRANS
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*&      --> lWA_ALV
*&      --> P_LANG2
*&      --> APPEND
*&      --> lWA_ALV
*&      --> TO
*&      --> GT_ALV
*&---------------------------------------------------------------------*
FORM sub_get_trans  USING    pv_char
                             pv_cha2
                             pv_lang2 TYPE sy-langu
                            .

  CHECK pv_char <> '' .
  DATA : lv_text TYPE string .
  lv_text =  pv_char.

  CALL METHOD zcl_ca_common=>customization_translation
    EXPORTING
      i_ztext = lv_text  "原文
      i_langu = pv_lang2
    IMPORTING
      e_ztext = lv_text. "译文
  pv_cha2 =  lv_text .


ENDFORM.
*&---------------------------------------------------------------------*
*& Form SUB_ADD_ALV
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*&      --> LT_PCX
*&      --> lWA_ALV
*&---------------------------------------------------------------------*
FORM sub_add_alv  TABLES   pt_pcx STRUCTURE lxe_pcx_s1
                  USING    pwa_alv TYPE ty_alv .

  DATA : lwa_pcx TYPE lxe_pcx_s1 .
  IF pt_pcx[] IS NOT INITIAL .
    LOOP AT pt_pcx INTO lwa_pcx .
      MOVE-CORRESPONDING lwa_pcx TO pwa_alv .
      PERFORM sub_get_trans USING pwa_alv-s_text   "按语言翻译
                                  pwa_alv-zdco1
                                  p_lang2 .
      APPEND pwa_alv TO gt_alv .
    ENDLOOP .
  ENDIF .

ENDFORM.
